rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // products 컬렉션: comfreec1@gmail.com만 접근 가능
    match /products/{productId} {
      allow read, write: if request.auth != null && request.auth.token.email == 'comfreec1@gmail.com';
    }
    // settings 문서 (카테고리): comfreec1@gmail.com만 접근 가능
    match /settings/{settingId} {
      allow read, write: if request.auth != null && request.auth.token.email == 'comfreec1@gmail.com';
    }
  }
}
