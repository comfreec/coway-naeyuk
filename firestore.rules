rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email == "comfreec1@gmail.com";
    }

    function isNumber(value) {
      return value is int || value is float;
    }

    function isValidRate(value) {
      return isNumber(value) && value >= 0 && value <= 100;
    }

    function isValidAmount(value) {
      return isNumber(value) && value >= 0 && value <= 1000000;
    }

    function hasValidProductFields(data) {
      return data.keys().hasOnly([
        'name',
        'rental',
        'contract',
        'halfDisc',
        'rerentalDisc',
        'disc',
        'extraDisc',
        'bundleDisc',
        'multiDisc',
        'competitor',
        'corasol',
        'card',
        'createdAt'
      ])
      && data.name is string
      && data.name.size() > 0
      && data.name.size() <= 80
      && isValidAmount(data.rental)
      && isValidRate(data.contract)
      && isValidRate(data.halfDisc)
      && isValidRate(data.rerentalDisc)
      && isValidRate(data.disc)
      && isValidRate(data.extraDisc)
      && isValidRate(data.bundleDisc)
      && isValidRate(data.multiDisc)
      && isValidAmount(data.competitor)
      && isValidAmount(data.corasol)
      && isValidAmount(data.card)
      && data.createdAt is int;
    }

    match /products/{productId} {
      allow read: if isOwner();
      allow create: if isOwner() && hasValidProductFields(request.resource.data);
      allow update: if isOwner()
                    && hasValidProductFields(request.resource.data)
                    && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner();
    }
  }
}
